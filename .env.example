# AntoGram build configuration
ANTOGRAM_APP_ID=123456
ANTOGRAM_APP_HASH=your_app_hash_here
ANTOGRAM_PLAYSTORE_APP_URL=https://play.google.com/store/apps/details?id=com.anto426.antogram
ANTOGRAM_GOOGLE_AUTH_CLIENT_ID=your_google_auth_client_id_here
ANTOGRAM_IS_BILLING_UNAVAILABLE=false
ANTOGRAM_SUPPORTS_PASSKEYS=true

# Optional overrides
# ANTOGRAM_DEBUG_VERSION=true
# ANTOGRAM_LOGS_ENABLED=true
# ANTOGRAM_DEBUG_PRIVATE_VERSION=false
# ANTOGRAM_USE_CLOUD_STRINGS=true
# ANTOGRAM_CHECK_UPDATES=true
# ANTOGRAM_BUILD_VERSION_STRING=1.0.0
